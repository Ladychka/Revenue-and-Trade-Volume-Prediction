# ==============================================================================
# Customs Analytics V2 - Environment Configuration Template
# ==============================================================================
# DO NOT commit real secrets or credentials to this file.
# Copy this file to '.env' and fill in your local values.
# ==============================================================================

# Application Settings
APP_NAME="Customs Analytics V2"
APP_ENV="development" # development, testing, staging, production
API_PREFIX="/api/v2"
DEBUG=True

# Security
# Generate using: openssl rand -hex 32
SECRET_KEY="replace_me_with_a_secure_random_string_in_production"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration (PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/customs_v2_db"

# Forecasting Configuration
# Default horizon for predictions if not specified
FORECAST_DEFAULT_HORIZON_MONTHS=6
FORECAST_CONFIDENCE_INTERVAL=0.95

# CORS Settings
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
